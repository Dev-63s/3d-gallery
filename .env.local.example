# ─────────────────────────────────────────────────────────────────────────────
# Supabase — copy these from your Supabase project → Settings → API
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Setup checklist:
#   1. Create a Supabase project at https://supabase.com
#   2. Copy SUPABASE_URL and SUPABASE_ANON_KEY from Project Settings → API
#   3. Run the migration: supabase/migrations/001_initial.sql in the SQL editor
#   4. Storage buckets ('models' and 'thumbnails') are created by the migration
#   5. Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────────────────
